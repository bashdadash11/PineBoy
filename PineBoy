<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PineBoyDesignz</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #0f0f0f;
    color: white;
}

/* HERO */
.hero {
    text-align: center;
    padding: 100px 20px;
    background: linear-gradient(to bottom, #111, #000);
}

.hero h1 {
    font-size: 70px;
    margin: 0;
    letter-spacing: 5px;
}

.hero p {
    font-size: 20px;
    color: #aaa;
    letter-spacing: 3px;
}

.btn {
    margin-top: 30px;
    display: inline-block;
    padding: 15px 30px;
    background: #1f7a1f;
    color: white;
    text-decoration: none;
    font-weight: bold;
    border-radius: 5px;
}

/* SECTION */
.section {
    padding: 60px 20px;
    text-align: center;
}

.section h2 {
    font-size: 32px;
    margin-bottom: 10px;
}

.section p {
    color: #bbb;
    max-width: 600px;
    margin: auto;
    line-height: 1.6;
}

/* PRODUCTS */
.products {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 20px;
    padding: 40px;
}

.card {
    background: #1a1a1a;
    padding: 20px;
    width: 250px;
    border-radius: 10px;
}

.card img {
    width: 100%;
    border-radius: 10px;
}

.price {
    color: #1f7a1f;
    font-weight: bold;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 30px;
    color: #666;
    font-size: 14px;
}
</style>
</head>

<body>

<!-- HERO -->
<div class="hero">
    <h1>PINEBOY</h1>
    <p>PINEBOY4LIFE</p>
    <a class="btn" href="#shop">Shop Now</a>
</div>

<!-- ABOUT -->
<div class="section">
    <h2>About PineBoyDesignz</h2>
    <p>
        Clean streetwear built on identity, confidence, and everyday style.
        PineBoyDesignz focuses on simple but bold designs printed on quality Gildan apparel.
    </p>
</div>

<!-- PRODUCTS -->
<div id="shop" class="section">
    <h2>Featured Drops</h2>

    <div class="products">

        <div class="card">
            <img src="https://via.placeholder.com/300x300">
            <h3>PineBoy Classic Tee</h3>
            <p class="price">$24.99</p>
        </div>

        <div class="card">
            <img src="https://via.placeholder.com/300x300">
            <h3>PineBoy4Life Tee</h3>
            <p class="price">$24.99</p>
        </div>

        <div class="card">
            <img src="https://via.placeholder.com/300x300">
            <h3>PineBoy Hoodie</h3>
            <p class="price">$39.99</p>
        </div>

    </div>
</div>

<!-- FOOTER -->
<footer>
    © 2026 PineBoyDesignz • PineBoy4Life
</footer>

</body>
</html>
